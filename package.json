{
  "name": "siteprinter-extension",
  "version": "1.0.0",
  "description": "SitePrinter extension - Capture full page screenshots and export to PDF",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "build:release": "vite build --mode release",
    "package:ext": "npm run build:release && zip -r siteprinter-extension.zip dist/ --exclude '*/.DS_Store'",
    "clean": "rm -rf dist dist-website siteprinter-extension.zip",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "terser": "^5.46.2",
    "vite": "^5.4.0",
    "vite-plugin-static-copy": "^1.0.6"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "jspdf": "^2.5.1"
  }
}
